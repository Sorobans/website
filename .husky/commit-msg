if ! pnpm exec commitlint --edit "$1"; then
  echo ""
  echo "Commit message format:"
  echo "  <type>(optional-scope): <subject>"
  echo ""
  echo "Allowed types:"
  echo "  feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"
  echo ""
  echo "Examples:"
  echo "  feat(home): add bilibili contact link"
  echo "  fix(sidebar): correct telegram profile url"
  echo "  chore: update pre-commit checks"
  exit 1
fi
