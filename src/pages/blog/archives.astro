---
import Layout from '@layouts/Layout.astro';
import { parseDate } from '@lib/datetime';
import { getArchiveData, getPostHref, getPostIndexMap } from '@lib/content';
import { CONTENT_PADDING } from '@constants/layout';
import { Routes } from '@constants/router';
import { blogLayoutConfig } from '@/config/blogLayoutConfig';
import Cover from '@components/ui/cover/Cover.astro';
import HomeSider from '@components/layout/HomeSider.astro';
import TwoColumnLayout from '@components/layout/TwoColumnLayout.astro';
import LayoutFooter from '@components/layout/LayoutFooter';
import { getLayoutFooterData } from '@lib/layout/footer-data';

const [{ posts, postsByYear, years }, postIndexMap, layoutFooterData] = await Promise.all([
  getArchiveData(),
  getPostIndexMap(),
  getLayoutFooterData(),
]);
---

<Layout title={`Archives | ${blogLayoutConfig.title}`} description="Article Archives">
  <TwoColumnLayout>
    <Cover slot="cover" title="Archives" />
    <HomeSider slot="sider" />
    <LayoutFooter slot="footer" {...layoutFooterData} />
    <div class={`shadow-box bg-gradient-start mx-0 flex w-full flex-col ${CONTENT_PADDING.standard}`}>
      <h2 class="shoka-decoration-circle group relative h-19 px-6 py-5 text-2xl/9 font-bold md:text-xl/9">
        <a href={Routes.Home} class="dashed-border text-muted-foreground group-hover:border-blue group-hover:text-blue border-b">
          Home
        </a>
        <span class="text-muted-foreground text-lg md:text-base"> / </span>
        Total {posts.length} Articles
      </h2>
      <div class="flex flex-col gap-4 md:gap-5">
        {
          years.map((year) => (
            <div>
              <h3 class="text-xl font-bold md:text-base">
                {year}
                <span class="text-muted-foreground ml-2 text-base md:text-sm">({postsByYear[Number(year)].length} Articles)</span>
              </h3>
              <div class="mt-2">
                {postsByYear[Number(year)].map((post) => (
                  <p class="shoka-decoration-circle group text-primary hover:text-blue relative px-6 py-2 text-base/9 md:flex md:flex-col md:items-stretch md:text-sm/9">
                    <span class="text-muted-foreground mr-2 text-xs">{parseDate(post.data.date, 'YYYY-MM-DD')}</span>
                    <a
                      href={getPostHref(post, postIndexMap)}
                      class="dashed-border text-primary hover:text-blue truncate transition-colors"
                    >
                      {post.data.title}
                    </a>
                  </p>
                ))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </TwoColumnLayout>
</Layout>