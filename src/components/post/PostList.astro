---
import EmptySvg from '@components/svg/EmptySvg';
import { defaultCoverList } from '@/config/blogLayoutConfig';
import { getBackgroundImages } from '@lib/backgrounds';
import { getPostHref, getPostIndexMap } from '@lib/content';
import type { Page } from 'astro';
import { shuffle } from 'es-toolkit';
import type { BlogPost } from '@/types/blog';
import Paginator from './Paginator.astro';
import PostItemCard from './PostItemCard.astro';

interface Props {
  posts?: BlogPost[];
  page?: Page<BlogPost>;
  showPaginator?: boolean;
  baseUrl?: string; // Base path for pagination
  isHomePage?: boolean; // Is home page
  isSimple?: boolean; // Hide cover
}

const { posts, page, showPaginator = true, baseUrl, isHomePage = false, isSimple = false } = Astro.props;
const [backgroundImages, postIndexMap] = await Promise.all([getBackgroundImages(), getPostIndexMap()]);
const covers = shuffle(backgroundImages.length ? backgroundImages : defaultCoverList);
---

{
  !posts?.length && (
    <div class="text-foreground/30 flex flex-col items-center gap-2 py-20">
      <EmptySvg className="fill-foreground/20" />
      <span>No posts published yet ~</span>
    </div>
  )
}
{
  posts && posts?.length > 0 && (
    <>
      <div class="flex flex-col gap-4">
        {posts.map((post, index) => (
          <PostItemCard
            key={post.id}
            data={post}
            showTags={!isSimple}
            leftClip={index % 2 === 0}
            randomCover={covers[index % covers.length]}
            hideCover={isSimple}
            isSimple={isSimple}
            href={getPostHref(post, postIndexMap)}
          />
        ))}
      </div>
      {showPaginator && page && <Paginator page={page} baseUrl={baseUrl} isHomePage={isHomePage} />}
    </>
  )
}